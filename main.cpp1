#include <stdio.h>
#include <stdlib.h>
#include <mpi.h>
#include <math.h>
#include <time.h>
#include <complex.h>
#include <hdf5.h>
#include <hdf5_hl.h>
#include "mesh.h"

int main(int argc, char *argv[])
{
    int myrank, nTasks;
    //MPI_Status status; 

    MPI_Init(&argc,&argv);
    MPI_Comm_size(MPI_COMM_WORLD, &nTasks);
    MPI_Comm_rank(MPI_COMM_WORLD, &myrank);

    Domain D;

    parameterSetting(&D,argv[1]);



    MPI_Finalize();

    return 0;
}
